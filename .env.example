# Copy this file to `.env` and paste your real keys in.
#   cp .env.example .env
# Then edit .env. The .env file is gitignored so your keys stay local.

# Streaming speech-to-text. Get from https://console.deepgram.com (API Keys).
DEEPGRAM_API_KEY=

# The LLM agent (gpt-4o-mini). Get from https://platform.openai.com/api-keys
# Needs a small prepaid balance under Settings -> Billing or you'll get a 429.
OPENAI_API_KEY=

# Streaming text-to-speech. Get from https://play.cartesia.ai (API Keys).
CARTESIA_API_KEY=
