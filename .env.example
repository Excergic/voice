# Copy this file to `.env` and paste your real keys in.
#   cp .env.example .env
# The .env file is gitignored — your keys never leave your machine.

# Streaming speech-to-text. Get from https://console.deepgram.com (API Keys).
DEEPGRAM_API_KEY=

# LLM (gpt-4o-mini). Get from https://platform.openai.com/api-keys
# Needs a prepaid balance under Settings -> Billing or you'll get a 429.
OPENAI_API_KEY=

# Streaming text-to-speech. Get from https://play.cartesia.ai (API Keys).
CARTESIA_API_KEY=

# Twilio credentials. Get from https://console.twilio.com
# Account SID and Auth Token are on your Twilio Console dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
